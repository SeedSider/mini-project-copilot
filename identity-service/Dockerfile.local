FROM golang:1.24-alpine AS builder

WORKDIR /app

COPY go.mod go.sum ./
RUN go mod download

COPY . .

RUN CGO_ENABLED=0 GOOS=linux go build -buildmode=pie -o app ./server/

FROM alpine:3.20

RUN apk add --no-cache ca-certificates tzdata

WORKDIR /app

COPY --from=builder /app/app .
COPY --from=builder /app/www ./www

EXPOSE 3031 9301

ENTRYPOINT ["./app"]
CMD ["grpc-gw-server", "--port1", "9301", "--port2", "3031", "--grpc-endpoint", ":9301"]
