# For local development (without Docker)
# DATABASE_URL=postgres://bankease:bankease123@localhost:5432/bankease_db?sslmode=disable

# For Docker Compose (default)
DATABASE_URL=postgres://bankease:bankease123@db:5432/bankease_db?sslmode=disable
PORT=8080

# Azure Blob Storage (for image upload endpoint POST /api/upload/image)
# Paste the full account-level SAS URL from the Azure portal
AZURE_STORAGE_SAS_URL=https://plnsa.blob.core.windows.net/?sv=2025-11-05&ss=bfqt&srt=sco&sp=rwdlacupiytfx&se=2026-04-11T14:56:36Z&st=2026-03-26T06:41:36Z&spr=https&sig=uqbKbqKFLDkoZX%2FxLosVhIardyUGotShuDGtHWv9yjE%3D
# Container must already exist in Azure Storage
AZURE_STORAGE_CONTAINER=images
