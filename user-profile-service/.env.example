# For local development (without Docker)
# DATABASE_URL=postgres://abc:abc123@localhost:5432/abc_db?sslmode=disable

# For Docker Compose (default)
DATABASE_URL=postgres://abc:abc123@localhost:5432/abc_db?sslmode=disable
PORT=8080

# JWT secret — must match the JWT_SECRET used by identity-service.
# Defaults to "secret" if not set (fine for dev, change for production).
JWT_SECRET=secret

# Azure Blob Storage (for image upload endpoint POST /api/upload/image)
# Paste the full account-level SAS URL from the Azure portal
AZURE_STORAGE_SAS_URL=https://abc.blob.core.windows.net
# Container must already exist in Azure Storage
AZURE_STORAGE_CONTAINER=images
